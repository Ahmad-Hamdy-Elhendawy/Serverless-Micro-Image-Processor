import boto3
import json

s3 = boto3.client('s3')

def lambda_handler(event, context):
    key = event.get('queryStringParameters', {}).get('filename', 'upload.jpg')
    url = s3.generate_presigned_url(
        'put_object',
        Params={'Bucket': 'img-raw-1-431451851290-us-east-1-an', 'Key': key},
        ExpiresIn=300
    )
    return {
        "statusCode": 200,
    "body": json.dumps({
        "upload_url": url
    })
    }
