{
  "StartAt": "ResizeImage",
  "States": {
    "ResizeImage": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:431451851290:function:Image-Processor-Functuon:$LATEST",
      "Next": "WatermarkImage",
      "OutputPath": "$"
    },
    "WatermarkImage": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:431451851290:function:LambdaWatermark:$LATEST",
      "InputPath": "$",
      "End": true,
      "OutputPath": "$"
    }
  }
}
